# =============================================================================
# Tironet — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to source control.
# =============================================================================

# Database (PostgreSQL)
# Production: use Neon or Supabase connection string
# Development: see docker-compose.yml for local Postgres
DATABASE_URL="postgresql://tironet:tironet@127.0.0.1:5434/tironet"

# PowerSync container DB URL — same credentials but using Docker-internal hostname.
# The PowerSync container can't reach 127.0.0.1:5434; it must use the service name.
# Development: always postgres:5432 (Docker internal)
# Production: same as DATABASE_URL (PowerSync Cloud connects to your DB directly)
PS_DATABASE_URL="postgresql://tironet:tironet@postgres:5432/tironet"

# NextAuth v5
AUTH_SECRET="<generate with: openssl rand -base64 32>"
NEXTAUTH_URL="http://localhost:3001"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Email — SMTP
# Development: Mailhog runs via docker-compose (web UI at http://localhost:8026)
# Production: use your SMTP provider (e.g. smtp://user:pass@smtp.example.com:587)
EMAIL_SERVER="smtp://localhost:1026"
FROM_EMAIL="Tironet <noreply@yourdomain.com>"

# Twilio Verify — WhatsApp / SMS OTP auth
# https://console.twilio.com → Verify → Services
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_VERIFY_SERVICE_SID="VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# PowerSync — offline-first sync
# Development: local PowerSync service via docker-compose (http://localhost:8080)
# Production: PowerSync Cloud instance URL
NEXT_PUBLIC_POWERSYNC_URL="http://localhost:8080"

# Shared secret used by both:
#   - The /api/powersync/token endpoint (signs JWTs for the client)
#   - The PowerSync service (verifies those JWTs)
# Generate with: openssl rand -base64 32
POWERSYNC_JWT_SECRET="<generate with: openssl rand -base64 32>"

# Local Docker PowerSync only — not needed for PowerSync Cloud
PS_JWT_SECRET_B64URL="<derived from POWERSYNC_JWT_SECRET>"
PS_MONGODB_URI="mongodb://mongo:27017/powersync"
PS_JWT_AUDIENCE="http://localhost:8080"

# Push Notifications (Web Push / VAPID)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="<your-vapid-public-key>"
VAPID_PRIVATE_KEY="<your-vapid-private-key>"
VAPID_SUBJECT="mailto:admin@yourdomain.com"

# Vercel Cron Secret — used to authenticate cron job requests
# Generate with: openssl rand -base64 32
CRON_SECRET="<generate with: openssl rand -base64 32>"

# Public app URL (used for invitation links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
