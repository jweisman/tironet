// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// NextAuth tables
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  givenName    String   @map("given_name")
  familyName   String   @map("family_name")
  rank         String?
  isAdmin      Boolean  @default(false) @map("is_admin")
  email        String?  @unique
  phone        String?  @unique @map("phone")
  profileImage String?  @map("profile_image")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  accounts              Account[]
  sessions              Session[]
  cycleAssignments      UserCycleAssignment[]
  invitationsSent       Invitation[]           @relation("InvitationSender")
  activitiesCreated     Activity[]
  activityReportsEdited ActivityReport[]
  requestsCreated       Request[]
  googleExportToken     GoogleExportToken?
  pushSubscriptions     PushSubscription[]
  notificationPreference NotificationPreference?

  @@map("users")
}

model Account {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token") @db.Text
  accessToken       String? @map("access_token") @db.Text
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token") @db.Text
  sessionState      String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz()

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Training hierarchy
// ---------------------------------------------------------------------------

model Cycle {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  companies        Company[]
  cycleAssignments UserCycleAssignment[]
  invitations      Invitation[]
  soldiers         Soldier[]
  activities       Activity[]
  requests         Request[]

  @@map("cycles")
}

model Company {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cycleId   String   @map("cycle_id") @db.Uuid
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  cycle    Cycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  platoons Platoon[]

  @@map("companies")
}

model Platoon {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  squads     Squad[]
  activities Activity[]

  @@map("platoons")
}

model Squad {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platoonId String   @map("platoon_id") @db.Uuid
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  platoon  Platoon   @relation(fields: [platoonId], references: [id], onDelete: Cascade)
  soldiers Soldier[]

  @@map("squads")
}

// ---------------------------------------------------------------------------
// Users & authorization
// ---------------------------------------------------------------------------

enum Role {
  company_commander
  deputy_company_commander
  platoon_commander
  platoon_sergeant
  squad_commander
}

enum UnitType {
  company
  platoon
  squad
}

model UserCycleAssignment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  cycleId   String   @map("cycle_id") @db.Uuid
  role      Role
  unitType  UnitType @map("unit_type")
  // Polymorphic FK: points to companies/platoons/squads based on unitType.
  // Referential integrity enforced at the application layer.
  unitId    String   @map("unit_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_user_assignments_user")
  @@index([cycleId], name: "idx_user_assignments_cycle")
  @@map("user_cycle_assignments")
}

model Invitation {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String?
  phone           String?   @map("phone")
  invitedByUserId String    @map("invited_by_user_id") @db.Uuid
  cycleId         String    @map("cycle_id") @db.Uuid
  role            Role
  unitType        UnitType  @map("unit_type")
  unitId          String    @map("unit_id") @db.Uuid
  givenName    String?   @map("given_name")
  familyName   String?   @map("family_name")
  rank         String?
  profileImage String?   @map("profile_image")
  token           String    @unique
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz()
  acceptedAt      DateTime? @map("accepted_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  invitedBy User  @relation("InvitationSender", fields: [invitedByUserId], references: [id])
  cycle     Cycle @relation(fields: [cycleId], references: [id])

  @@index([token], name: "idx_invitations_token")
  @@index([email], name: "idx_invitations_email")
  @@map("invitations")
}

// ---------------------------------------------------------------------------
// Soldiers
// ---------------------------------------------------------------------------

enum SoldierStatus {
  active
  transferred
  dropped
  injured
}

model Soldier {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cycleId      String        @map("cycle_id") @db.Uuid
  squadId      String        @map("squad_id") @db.Uuid
  givenName    String        @map("given_name")
  familyName   String        @map("family_name")
  idNumber     String?       @map("id_number")
  rank         String?
  status       SoldierStatus @default(active)
  profileImage String?       @map("profile_image")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  cycle           Cycle            @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  squad           Squad            @relation(fields: [squadId], references: [id])
  activityReports ActivityReport[]
  requests        Request[]

  @@index([cycleId, squadId], name: "idx_soldiers_cycle_squad")
  @@index([squadId, status], name: "idx_soldiers_squad_status")
  @@map("soldiers")
}

// ---------------------------------------------------------------------------
// Activities
// ---------------------------------------------------------------------------

enum ActivityStatus {
  draft
  active
}

enum ActivityResult {
  passed
  failed
  na
}

model ActivityType {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  icon        String
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  score1Label String?  @default("ציון") @map("score1_label")
  score2Label String?  @map("score2_label")
  score3Label String?  @map("score3_label")
  score4Label String?  @map("score4_label")
  score5Label String?  @map("score5_label")
  score6Label String?  @map("score6_label")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  activities Activity[]

  @@map("activity_types")
}

model Activity {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platoonId       String         @map("platoon_id") @db.Uuid
  cycleId         String         @map("cycle_id") @db.Uuid
  activityTypeId  String         @map("activity_type_id") @db.Uuid
  name            String
  date            DateTime       @db.Date
  isRequired      Boolean        @default(true) @map("is_required")
  status          ActivityStatus @default(draft)
  createdByUserId String         @map("created_by_user_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

  platoon      Platoon        @relation(fields: [platoonId], references: [id], onDelete: Cascade)
  cycle        Cycle          @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  activityType ActivityType   @relation(fields: [activityTypeId], references: [id])
  createdBy    User           @relation(fields: [createdByUserId], references: [id])
  reports      ActivityReport[]

  @@index([platoonId, cycleId], name: "idx_activities_platoon_cycle")
  @@index([date(sort: Desc)], name: "idx_activities_date")
  @@map("activities")
}

model ActivityReport {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  activityId      String         @map("activity_id") @db.Uuid
  soldierId       String         @map("soldier_id") @db.Uuid
  result          ActivityResult
  grade1          Decimal?       @db.Decimal
  grade2          Decimal?       @db.Decimal
  grade3          Decimal?       @db.Decimal
  grade4          Decimal?       @db.Decimal
  grade5          Decimal?       @db.Decimal
  grade6          Decimal?       @db.Decimal
  note            String?
  updatedByUserId String         @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

  activity  Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  soldier   Soldier  @relation(fields: [soldierId], references: [id], onDelete: Cascade)
  updatedBy User     @relation(fields: [updatedByUserId], references: [id])

  @@unique([activityId, soldierId])
  @@index([activityId], name: "idx_activity_reports_activity")
  @@index([soldierId], name: "idx_activity_reports_soldier")
  @@map("activity_reports")
}

// ---------------------------------------------------------------------------
// Requests
// ---------------------------------------------------------------------------

enum RequestType {
  leave
  medical
  hardship
}

enum RequestStatus {
  open
  approved
  denied
}

enum Transportation {
  public_transit
  shuttle
  military_transport
  other
}

model Request {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cycleId         String        @map("cycle_id") @db.Uuid
  soldierId       String        @map("soldier_id") @db.Uuid
  type            RequestType
  status          RequestStatus @default(open)
  assignedRole    Role?         @map("assigned_role")
  createdByUserId String        @map("created_by_user_id") @db.Uuid

  // Common
  description     String?

  // Leave fields
  place           String?
  departureAt     DateTime?     @map("departure_at") @db.Timestamptz()
  returnAt        DateTime?     @map("return_at") @db.Timestamptz()
  transportation  Transportation?

  // Medical fields
  urgent          Boolean?
  paramedicDate   DateTime?     @map("paramedic_date") @db.Date
  appointmentDate DateTime?     @map("appointment_date") @db.Date
  appointmentPlace String?      @map("appointment_place")
  appointmentType  String?      @map("appointment_type")
  sickLeaveDays   Int?          @map("sick_leave_days")

  // Hardship fields
  specialConditions Boolean?    @map("special_conditions")

  // Denial
  denialReason    String?       @map("denial_reason")

  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  cycle           Cycle         @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  soldier         Soldier       @relation(fields: [soldierId], references: [id], onDelete: Cascade)
  createdBy       User          @relation(fields: [createdByUserId], references: [id])

  @@index([cycleId, status], name: "idx_requests_cycle_status")
  @@index([soldierId], name: "idx_requests_soldier")
  @@map("requests")
}

// ---------------------------------------------------------------------------
// Push notifications
// ---------------------------------------------------------------------------

model PushSubscription {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_push_subscriptions_user")
  @@map("push_subscriptions")
}

model NotificationPreference {
  id                       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                   String  @unique @map("user_id") @db.Uuid
  dailyTasksEnabled        Boolean @default(true) @map("daily_tasks_enabled")
  requestAssignmentEnabled Boolean @default(true) @map("request_assignment_enabled")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ---------------------------------------------------------------------------
// Google Sheets export tokens (incremental OAuth)
// ---------------------------------------------------------------------------

model GoogleExportToken {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  accessToken  String   @map("access_token") @db.Text
  refreshToken String   @map("refresh_token") @db.Text
  expiresAt    DateTime @map("expires_at") @db.Timestamptz()
  scope        String
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_export_tokens")
}
