# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/e2e/.auth/
/.e2e-tokens.json
/test-results/
/playwright-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — commit only .env.example, never the real secrets
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# PowerSync — WASM + worker assets copied from node_modules by postinstall.
# Regenerated on every `npm install`; no need to commit.
/public/@powersync

# iOS PWA splash screens — generated by scripts/generate-splash.mjs
/public/splash

# Terraform
infra/**/.terraform/
infra/**/*.tfstate
infra/**/*.tfstate.*
infra/**/crash.log
infra/**/.terraform.lock.hcl
infra/**/lambda.zip

# Local vars
infra/**/terraform.tfvars